<?xml version="1.0" encoding="UTF-8"?>
<module id="biz.avasis.polarion.copilot" version="1.0.0">
	<!-- Velocity context variable for the Copilot plugin. Accessible in wiki and rich pages as $ava-copilot -->
	<contribution configuration-id="com.polarion.alm.wiki.renderingContext">
		<item key="ava-copilot" value="instance:biz.avasis.polarion.copilot.services.CopilotWikiService" />
	</contribution>
	<contribution configuration-id="com.polarion.alm.richpages.velocityContext">
		<item key="ava-copilot" value="instance:biz.avasis.polarion.copilot.services.CopilotWikiService" />
	</contribution>
</module>