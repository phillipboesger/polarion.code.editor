<project xmlns="http://maven.apache.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>boesger.polarion</groupId>
  <artifactId>code-editor</artifactId>
  <version>1.0.0</version>
  <packaging>jar</packaging>

  <name>Polarion Code Editor Plugin</name>
  <description>Comprehensive Code Editor for Polarion Administration.</description>
  <url>https://github.com/phillipboesger/polarion.code.editor</url>

  <organization>
    <name>Bösger</name>
    <url>https://digital.boesger.com</url>
  </organization>

  <scm>
    <connection>scm:git:https://github.com/phillipboesger/polarion.code.editor.git</connection>
    <developerConnection>scm:git:https://github.com/phillipboesger/polarion.code.editor.git</developerConnection>
    <url>https://github.com/phillipboesger/polarion.code.editor</url>
    <tag>HEAD</tag>
  </scm>

  <!--
    Polarion platform JARs are published to GitHub Packages.
    CI authenticates via the PACKAGES_TOKEN secret (PAT with read:packages).
    The server id "github" is injected by actions/setup-java in the CI workflow.
  -->
  <repositories>
    <repository>
      <id>github</id>
      <url>https://maven.pkg.github.com/avasis-solutions/masterPom-plugins</url>
      <snapshots>
        <enabled>true</enabled>
      </snapshots>
    </repository>
  </repositories>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
    <maven.compiler.release>21</maven.compiler.release>
    <!-- OSGi Bundle-Version must not contain SNAPSHOT; keep in sync with project.version -->
    <manifest.version>1.0.0</manifest.version>
    <!-- Polarion platform version used for OSGi Require-Bundle and compilation -->
    <polarion.version>3.25.12</polarion.version>
    <!-- subterra versioning follows a separate scheme; 5.25.12 aligns with 3.25.12 -->
    <subterra.version>5.25.12</subterra.version>
  </properties>

  <build>
    <resources>
      <resource>
        <directory>META-INF</directory>
        <includes>
          <include>hivemodule.xml</include>
        </includes>
        <targetPath>META-INF</targetPath>
      </resource>
      <resource>
        <directory>src/main/webapp</directory>
        <targetPath>src/main/webapp</targetPath>
        <excludes>
          <!-- Only the minified build is used at runtime; dev, esm and source-maps are not needed in the JAR -->
          <exclude>resources/lib/monaco-editor/dev/**</exclude>
          <exclude>resources/lib/monaco-editor/esm/**</exclude>
          <exclude>resources/lib/monaco-editor/min-maps/**</exclude>
        </excludes>
      </resource>
      <resource>
        <directory>.</directory>
        <includes>
          <include>plugin.xml</include>
        </includes>
      </resource>
    </resources>

    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-clean-plugin</artifactId>
          <version>3.3.2</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-resources-plugin</artifactId>
          <version>3.3.1</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.13.0</version>
          <configuration>
            <annotationProcessorPaths>
              <path>
                <groupId>org.projectlombok</groupId>
                <artifactId>lombok</artifactId>
                <version>1.18.42</version>
              </path>
            </annotationProcessorPaths>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <version>3.2.5</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-jar-plugin</artifactId>
          <version>3.3.0</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-install-plugin</artifactId>
          <version>3.1.1</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-deploy-plugin</artifactId>
          <version>3.1.1</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-release-plugin</artifactId>
          <version>3.0.1</version>
          <configuration>
            <tagNameFormat>v@{project.version}</tagNameFormat>
            <autoVersionSubmodules>true</autoVersionSubmodules>
            <releaseProfiles>release</releaseProfiles>
          </configuration>
        </plugin>
      </plugins>
    </pluginManagement>

    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>3.4.1</version>
        <executions>
          <execution>
            <id>enforce-versions</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <configuration>
              <rules>
                <requireJavaVersion>
                  <version>[21,)</version>
                </requireJavaVersion>
                <requireMavenVersion>
                  <version>[3.8,)</version>
                </requireMavenVersion>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <configuration>
          <finalName>${project.groupId}.${project.artifactId}-${project.version}</finalName>
          <archive>
            <manifestEntries>
              <Bundle-ManifestVersion>2</Bundle-ManifestVersion>
              <Bundle-Name>${project.name}</Bundle-Name>
              <Bundle-SymbolicName>${project.groupId}.${project.artifactId};singleton:=true</Bundle-SymbolicName>
              <Bundle-Version>${manifest.version}</Bundle-Version>
              <Bundle-Vendor>${project.organization.name}</Bundle-Vendor>
              <Require-Bundle>com.polarion.portal.tomcat,com.polarion.platform.persistence,org.apache.hivemind,com.polarion.alm.ui;bundle-version="${polarion.version}",com.polarion.alm.tracker;bundle-version="${polarion.version}",com.polarion.platform.guice;bundle-version="${polarion.version}",com.polarion.core.util;bundle-version="${polarion.version}",com.polarion.platform.repository;bundle-version="${polarion.version}",com.polarion.platform;bundle-version="${polarion.version}",org.eclipse.core.runtime,com.polarion.psvn.launcher,org.apache.commons.io,org.apache.commons.commons-fileupload,com.google.gson</Require-Bundle>
              <Import-Package>org.apache.log4j</Import-Package>
            </manifestEntries>
          </archive>
        </configuration>
      </plugin>
      <plugin>
        <!-- Mockito requires open modules for reflection under Java 21+ -->
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <argLine>
            -XX:+EnableDynamicAgentLoading
            --add-opens java.base/java.lang=ALL-UNNAMED
            --add-opens java.base/java.util=ALL-UNNAMED
            --add-opens java.base/java.lang.reflect=ALL-UNNAMED
          </argLine>
        </configuration>
      </plugin>
    </plugins>
  </build>

  <dependencies>

    <!-- ===== Polarion Platform (provided by OSGi runtime) ===== -->
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>platform</artifactId>
      <version>${polarion.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>alm.projects</artifactId>
      <version>${polarion.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>platform.persistence</artifactId>
      <version>${polarion.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>platform.repository</artifactId>
      <version>${polarion.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>alm.ui</artifactId>
      <version>${polarion.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>alm.tracker</artifactId>
      <version>${polarion.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>core.util</artifactId>
      <version>${polarion.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>subterra.base.data</artifactId>
      <version>${subterra.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.polarion</groupId>
      <artifactId>subterra.base.core</artifactId>
      <version>${subterra.version}</version>
      <scope>provided</scope>
    </dependency>

    <!-- ===== Servlet API (provided by Polarion / Tomcat) ===== -->
    <dependency>
      <groupId>javax.servlet</groupId>
      <artifactId>javax.servlet-api</artifactId>
      <version>3.1.0</version>
      <scope>provided</scope>
    </dependency>

    <!-- ===== Third-party (provided by OSGi runtime) ===== -->
    <dependency>
      <groupId>com.google.code.gson</groupId>
      <artifactId>gson</artifactId>
      <version>2.10.1</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>commons-io</groupId>
      <artifactId>commons-io</artifactId>
      <version>2.15.1</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>commons-fileupload</groupId>
      <artifactId>commons-fileupload</artifactId>
      <version>1.5</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.apache.logging.log4j</groupId>
      <artifactId>log4j-api</artifactId>
      <version>2.20.0</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.apache.logging.log4j</groupId>
      <artifactId>log4j-core</artifactId>
      <version>2.20.0</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>velocity-tools</groupId>
      <artifactId>velocity-tools</artifactId>
      <version>1.4</version>
      <scope>provided</scope>
    </dependency>

    <!-- ===== Code generation (compile-time only) ===== -->
    <dependency>
      <groupId>org.projectlombok</groupId>
      <artifactId>lombok</artifactId>
      <version>1.18.42</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.jetbrains</groupId>
      <artifactId>annotations</artifactId>
      <version>24.1.0</version>
      <scope>provided</scope>
    </dependency>

    <!-- ===== Test ===== -->
    <dependency>
      <groupId>junit</groupId>
      <artifactId>junit</artifactId>
      <version>4.13.2</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.mockito</groupId>
      <artifactId>mockito-core</artifactId>
      <version>5.11.0</version>
      <scope>test</scope>
    </dependency>

  </dependencies>

</project>
