{
  "name": "polarion-ui-tests",
  "version": "1.0.0",
  "description": "Playwright UI tests for the Polarion Code Editor plugin",
  "scripts": {
    "test": "./node_modules/.bin/playwright test",
    "test:fast": "./node_modules/.bin/playwright test --workers=1 --max-failures=1 --reporter=line",
    "test:debug": "./node_modules/.bin/playwright test --workers=1 --max-failures=1 --trace=on --reporter=line",
    "test:headed": "./node_modules/.bin/playwright test --headed",
    "report": "./node_modules/.bin/playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.6.0"
  }
}
