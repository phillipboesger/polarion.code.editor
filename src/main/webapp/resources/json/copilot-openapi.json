{
  "openapi": "3.0.3",
  "info": {
    "title": "avasis Copilot Configuration API",
    "version": "1.0.0",
    "description": "This REST API provides endpoints for managing Copilot configurations within Polarion. It supports loading and storing configuration files in both JSON and XML formats. The API handles project-specific configurations as well as global settings stored in the `.avasis` repository folder. Additionally, it offers capabilities to retrieve image resources (e.g., SVG icons) used within the Copilot interface."
  },
  "paths": {
    "/polarion/copilot/api/projects/{projectId}/config/json/{fileName}": {
      "get": {
        "tags": [
          "config"
        ],
        "summary": "Load JSON configuration file",
        "operationId": "getJsonConfig",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Polarion project ID or the literal 'global' for the global .avasis folder"
          },
          {
            "name": "fileName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File name relative to the .avasis folder (e.g. config/copilot.json)"
          }
        ],
        "responses": {
          "200": {
            "description": "JSON configuration successfully loaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "put": {
        "tags": [
          "config"
        ],
        "summary": "Create or update JSON configuration file",
        "operationId": "putJsonConfig",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fileName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "File created or updated"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/polarion/copilot/api/projects/{projectId}/config/json": {
      "get": {
        "tags": [
          "config"
        ],
        "summary": "List all JSON configuration files",
        "operationId": "listJsonConfigs",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Polarion project ID or 'global'"
          }
        ],
        "responses": {
          "200": {
            "description": "List of configurations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "fileName": {
                        "type": "string"
                      },
                      "projectId": {
                        "type": "string"
                      },
                      "global": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/polarion/copilot/api/projects/{projectId}/config/xml/{fileName}": {
      "get": {
        "tags": [
          "config"
        ],
        "summary": "Load XML configuration file",
        "operationId": "getXmlConfig",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fileName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "XML configuration successfully loaded",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "put": {
        "tags": [
          "config"
        ],
        "summary": "Create or update XML configuration file",
        "operationId": "putXmlConfig",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fileName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "File created or updated"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/polarion/copilot/api/projects/{projectId}/config/img/{fileName}": {
      "get": {
        "tags": [
          "config"
        ],
        "summary": "Load image file (SVG, PNG, JPG, GIF)",
        "operationId": "getImage",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fileName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image content",
            "content": {
              "image/svg+xml": {},
              "image/png": {},
              "image/jpeg": {},
              "image/gif": {},
              "application/octet-stream": {}
            }
          },
          "404": {
            "description": "Image not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  }
}