## Velocity template for document comparison actions
## Expected parameter: $macroName ("compareLast" or "compareVersion")

#set($llmHelper = $ava-copilot.getLlmHelper)
#set($moduleHelper = $ava-copilot.getModuleHelper)
#set($coreModuleHelper = $ava-utils.getModuleHelper)

## Helper macro to invoke the LLM for content comparison
## Parameters:
## - $currentContent: The HTML content of the current document version
## - $otherContent: The HTML content of the comparison version (baseline or previous status)
#macro(runLlmComparison $currentContent $otherContent)
  #set($projectId = $project.id)
  #set($llmConfig = $llmHelper.resolveLlmConfig($projectId, "avaCopilot/documentCompare.json"))
  
  #if($llmConfig)
      $ava-copilot.log("Invoking LLM...", "INFO")
      #set($llmRawResponse = $llmHelper.invokeLlmWithContents($llmConfig, $currentContent, $otherContent))
      #if($llmRawResponse)
        $ava-copilot.log("LLM response received", "INFO")
        #set($llmFormatted = $llmRawResponse.replace('\r','').replace('\n','<br/>'))
        <div class="avaCopilot-doc-diff-llm">
           $!llmFormatted
        </div>
      #else
        $ava-copilot.log("LLM response empty", "ERROR")
        <p class="avaCopilot-doc-diff-error">No AI analysis available (empty response).</p>
      #end
  #else
      $ava-copilot.log("No LLM config found", "ERROR")
      <p class="avaCopilot-doc-diff-error">No AI configuration available.</p>
  #end
#end

## Macro to compare the current document with a previous version
## Logic:
## 1. Checks if a specific 'compareStatusId' is configured.
## 2. If yes, finds the last signed version in that status.
## 3. If no, falls back to the last baseline version.
## 4. Invokes 'runLlmComparison' with the content of both versions.
#macro(compareLast)
  $ava-copilot.log("Starting compareLast macro", "INFO")
  ## Current Document (HomePage Content)
  #set($currentModule = $document)
  #set($currentContent = $coreModuleHelper.renderHomePageContentAsSystemUser($currentModule, "html").getContent())
  $ava-copilot.log("Current content length: $currentContent.length()", "DEBUG")

  ## Load configuration first to determine the comparison strategy (e.g. by status)
  #set($projectId = $project.id)
  #set($llmConfig = $llmHelper.resolveLlmConfig($projectId, "avaCopilot/documentCompare.json"))

  ## Determine previous version
  #set($previousModule = false)
  #if($compareStatusId && !$compareStatusId.isEmpty())
    $ava-copilot.log("Comparing against status: $compareStatusId", "INFO")
    ## If a status ID is configured, search for the last signed version in that status
    #set($previousModule = $moduleHelper.getLastSignedVersion($currentModule, $compareStatusId))
    $ava-copilot.log("Previous module found by status: $previousModule", "DEBUG")
  #else
    $ava-copilot.log("Comparing against last baseline", "INFO")
    ## Fallback: previous revision
    #set($previousModule = $moduleHelper.getPreviousVersion($currentModule))
  #end

  #if($previousModule)
    #set($previousContent = $coreModuleHelper.renderHomePageContentAsSystemUser($previousModule, "html").getContent())
    $ava-copilot.log("Previous content length: $previousContent.length()", "DEBUG")
    
    #runLlmComparison($currentContent $previousContent)
  #else
    $ava-copilot.log("No previous module found", "WARN")
    #set($previousContent = "")
    <p class="avaCopilot-doc-diff-error">No suitable previous version found for comparison (Status: $!compareStatusId); AI analysis not possible.</p>
  #end
#end

## Macro to compare the current document with a specific revision
## Logic:
## - If 'uiMode' is 'sidePanel', renders a list of available baselines for selection.
## - If 'targetRevision' is provided, fetches that specific version.
## - Invokes 'runLlmComparison' with the content of the current and target version.
#macro(compareVersion)
  $ava-copilot.log("Starting compareVersion macro", "INFO")
  
  ## Check if targetRevision is provided in context (JSON) or request (Form)
  #if(!$targetRevision && $request)
    #set($targetRevision = $request.getParameter("targetRevision"))
  #end
  
  #set($coreModuleHelper = $ava-utils.getModuleHelper)
  #set($currentModule = $document)
  
  ## Use the uiMode (passed from JS) to decide whether to render the selection list or the result.
  ## 'sidePanel' -> Show list of baselines
  ## 'writeToField' (with targetRevision) -> Show comparison result
  #if($uiMode.isEquals("sidePanel"))
    $ava-copilot.log("UI Mode is sidePanel, showing selection UI", "INFO")
    #set($baselines = $
    <div class="avaCopilot-version-list-container">
       <h4>Select Baseline</h4>
       <div class="avaCopilot-version-list">
          #foreach($baseline in $baselines)
             #set($rev = $baseline.baseRevision)
             #set($name = $baseline.name)
             #set($author = $baseline.author.id)
             <div class="avaCopilot-version-item" 
                  data-ava-action="compareVersion"
                  data-ava-params='{"targetRevision": "$rev", "loadingLabel": "Compare to Baseline $name"}'>
                <strong>$!name</strong><br/>
                <span>Revision $rev ($author)</span>
             </div>
          #end
       </div>
    </div>
    
  #elseif($targetRevision && !$targetRevision.isEmpty)
    $ava-copilot.log("Comparing against revision: $targetRevision", "INFO")
    ## Render Comparison Result
    #set($currentContent = $coreModuleHelper.renderHomePageContentAsSystemUser($currentModule, "html").getContent())
    #set($targetModule = $ava-copilot.moduleHelper.getModuleVersion($currentModule, $targetRevision))

    #if($targetModule)
        #set($targetContent = $coreModuleHelper.renderHomePageContentAsSystemUser($targetModule, "html").getContent())
        
        #runLlmComparison($currentContent $targetContent)
    #else
        $ava-copilot.log("Target revision not found", "ERROR")
        <p class="avaCopilot-doc-diff-error">Target revision $targetRevision not found.</p>
    #end
  
  #else
    $ava-copilot.log("Invalid state: uiMode=$!uiMode but no targetRevision provided", "WARN")
    <p class="avaCopilot-doc-diff-error">Please select a baseline to compare.</p>
  #end
#end
